# Для подключения к PostgreSQL
POSTGRES_HOST=db
DB_PORT=5432
DB_NAME=db-name
POSTGRES_USER=postgres-name
POSTGRES_PASSWORD=postgres-password

# Для подключения к Qdrant
QDRANT_HOST=localhost
QDRANT_PORT_HTTP=6333
QDRANT_PORT_GRPC=6334
VECT_MODEL=bge-m3|all-mpnet-base-v2

# Сервисы
## Основной сервис
API_PORT=8008

## Векторизация для qdrant
VECT_QD_PORT=8010

## Обращение к LLM
LLM_PORT=8011
LLAMA_MODEL_FILE=model.gguf
LLAMA_MODEL_ALIAS=local-gguf
LLAMA_CTX_SIZE=4096
LLAMA_N_GPU_LAYERS=0
LLAMA_PARALLEL=1
LLAMA_GENERATION_TEMPERATURE=0.2
LLAMA_GENERATION_MAX_TOKENS=1024
LLAMA_REQUEST_TIMEOUT=600
